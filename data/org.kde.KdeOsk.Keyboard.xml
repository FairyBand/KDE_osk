<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/Keyboard">
  <interface name="org.kde.KdeOsk.Keyboard">
    <method name="showKeyboard"/>
    <method name="hideKeyboard"/>
    <method name="setTextFocusActive">
      <arg name="active" type="b" direction="in"/>
    </method>
    <property name="visible" type="b" access="read"/>
    <property name="autoShowEnabled" type="b" access="readwrite"/>
    <signal name="visibleChanged">
      <arg name="visible" type="b"/>
    </signal>
    <signal name="autoShowEnabledChanged">
      <arg name="enabled" type="b"/>
    </signal>
    <signal name="commitTextRequested">
      <arg name="text" type="s"/>
    </signal>
  </interface>
</node>
