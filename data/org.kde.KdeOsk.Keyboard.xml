<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/Keyboard">
  <interface name="org.kde.KdeOsk.Keyboard">
    <method name="showKeyboard"/>
    <method name="forceShowKeyboard"/>
    <method name="hideKeyboard"/>
    <method name="setTextFocusActive">
      <arg name="active" type="b" direction="in"/>
    </method>
    <method name="setTextFocusRect">
      <arg name="active" type="b" direction="in"/>
      <arg name="x" type="i" direction="in"/>
      <arg name="y" type="i" direction="in"/>
      <arg name="width" type="i" direction="in"/>
      <arg name="height" type="i" direction="in"/>
    </method>
    <property name="visible" type="b" access="read"/>
    <property name="textFocusActive" type="b" access="read"/>
    <property name="focusRectX" type="i" access="read"/>
    <property name="focusRectY" type="i" access="read"/>
    <property name="focusRectWidth" type="i" access="read"/>
    <property name="focusRectHeight" type="i" access="read"/>
    <property name="autoShowEnabled" type="b" access="readwrite"/>
    <property name="ignoreHardwareKeyboard" type="b" access="readwrite"/>
    <property name="inputBackendAvailable" type="b" access="read"/>
    <property name="inputBackendError" type="s" access="read"/>
    <property name="capsLockActive" type="b" access="read"/>
    <signal name="visibleChanged">
      <arg name="visible" type="b"/>
    </signal>
    <signal name="autoShowEnabledChanged">
      <arg name="enabled" type="b"/>
    </signal>
    <signal name="textFocusActiveChanged">
      <arg name="active" type="b"/>
    </signal>
    <signal name="capsLockActiveChanged">
      <arg name="active" type="b"/>
    </signal>
    <signal name="focusRectChanged"/>
    <signal name="commitTextRequested">
      <arg name="text" type="s"/>
    </signal>
  </interface>
</node>
